<% if model.errors.any? %>
  <div class="alert alert-danger mb-3">
    <h5 class="alert-heading"><%= pluralize(model.errors.count, "error") %> prevented this record from being saved:</h5>
    <ul class="mb-0">
      <% model.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
