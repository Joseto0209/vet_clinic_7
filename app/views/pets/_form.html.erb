<%= render "shared/error_messages", model: pet %>

<%= form_with(model: pet, class: "needs-validation") do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :owner_id, "Owner", class: "form-label" %>
    <%= f.collection_select :owner_id, Owner.all, :id, :first_name, { prompt: "Select an owner" }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :species, class: "form-label" %>
    <%= f.select :species, %w[dog cat rabbit bird reptile other].map { |s| [s.titleize, s] }, { prompt: "Select a species" }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :breed, class: "form-label" %>
    <%= f.text_field :breed, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :date_of_birth, class: "form-label" %>
    <%= f.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :weight, "Weight (kg)", class: "form-label" %>
    <%= f.number_field :weight, class: "form-control", step: 0.1 %>
  </div>

  <div class="mb-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
