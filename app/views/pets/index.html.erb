<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Pets Directory</h1>
  <%= link_to "New Pet", new_pet_path, class: "btn btn-primary" %>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Photo</th>
          <th>Name</th>
          <th>Species</th>
          <th>Breed</th>
          <th>Owner Name</th>
          <th>Date of Birth</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @pets.each do |pet| %>
          <tr>
            <td>
              <% if pet.photo.attached? %>
                <%= image_tag pet.photo.variant(resize_to_fill: [120, 120]), class: "rounded-circle shadow-sm", style: "width: 60px; height: 60px; object-fit: cover;" %>
              <% else %>
                <div class="bg-light rounded-circle shadow-sm d-flex align-items-center justify-content-center text-muted" style="width: 60px; height: 60px; font-size: 0.7rem;">
                  N/A
                </div>
              <% end %>
            </td>
            <td class="align-middle">
              <%= link_to pet.name, pet_path(pet), class: "text-decoration-none fw-bold text-success" %>
            </td>
            <td><%= pet.species %></td>
            <td><%= pet.breed %></td>
            <td><%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", owner_path(pet.owner), class: "text-decoration-none text-dark" %></td>
            <td><%= pet.date_of_birth&.strftime("%B %d, %Y") %></td>
            <td>
              <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-outline-warning me-1" %>
              <%= button_to "Delete", pet_path(pet), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Are you sure?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>