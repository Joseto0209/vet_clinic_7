<div class="mb-4">
  <%= link_to "← Back to Appointments", appointments_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
    <h2 class="h4 mb-0">Appointment Details</h2>
    <div class="d-flex align-items-center gap-2">
      <span class="badge bg-light text-dark fs-6"><%= @appointment.status.titleize %></span>
      <%= link_to "Edit", edit_appointment_path(@appointment), class: "btn btn-sm btn-light" %>
      <%= button_to "Delete", appointment_path(@appointment), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?" } %>
    </div>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6">
        <p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y at %I:%M %p") %></p>
        <p><strong>Reason:</strong> <%= @appointment.reason %></p>
      </div>
      <div class="col-md-6">
        <p><strong>Pet:</strong> <%= link_to @appointment.pet.name, pet_path(@appointment.pet), class: "text-decoration-none" %></p>
        <p><strong>Veterinarian:</strong> <%= link_to "#{@appointment.vet.first_name} #{@appointment.vet.last_name}", vet_path(@appointment.vet), class: "text-decoration-none" %></p>
      </div>
    </div>
  </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3 class="h5 mb-0">Treatments Administered</h3>
  <%= link_to "New Treatment", new_appointment_treatment_path(@appointment), class: "btn btn-sm btn-primary" %>
</div>

<% if @appointment.treatments.any? %>
  <div class="card shadow-sm">
    <table class="table table-bordered mb-0">
      <thead class="table-light">
        <tr>
          <th>Name</th>
          <th>Medication</th>
          <th>Dosage</th>
          <th>Administered At</th>
          <th>Notes</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @appointment.treatments.each do |treatment| %>
          <tr>
            <td class="fw-bold"><%= treatment.name %></td>
            <td><%= treatment.medication %></td>
            <td><%= treatment.dosage %></td>
            <td><%= treatment.administered_at&.strftime("%B %d, %Y %I:%M %p") %></td>
            <td><%= treatment.clinical_notes %></td>
            <td>
              <%= link_to "Edit", edit_appointment_treatment_path(@appointment, treatment), class: "btn btn-sm btn-outline-warning me-1" %>
              <%= button_to "Delete", appointment_treatment_path(@appointment, treatment), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Are you sure?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No treatments recorded for this appointment.</p>
<% end %>