<%= render "shared/error_messages", model: appointment %>

<%= form_with(model: appointment, class: "needs-validation") do |f| %>
  <div class="mb-3">
    <%= f.label :pet_id, "Pet", class: "form-label" %>
    <%= f.collection_select :pet_id, Pet.all, :id, :name, { prompt: "Select a pet" }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :vet_id, "Veterinarian", class: "form-label" %>
    <%= f.collection_select :vet_id, Vet.all, :id, :first_name, { prompt: "Select a veterinarian" }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :date, class: "form-label" %>
    <%= f.datetime_field :date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :reason, class: "form-label" %>
    <%= f.text_area :reason, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3">
    <%= f.label :status, class: "form-label" %>
    <%= f.select :status, Appointment.statuses.keys.map { |s| [s.titleize, s] }, { prompt: "Select a status" }, { class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
