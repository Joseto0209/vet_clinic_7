<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Owners Directory</h1>
  <%= link_to "New Owner", new_owner_path, class: "btn btn-primary" %>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Full Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Number of Pets</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @owners.each do |owner| %>
          <tr>
            <td>
              <%= link_to "#{owner.first_name} #{owner.last_name}", owner_path(owner), class: "text-decoration-none fw-bold" %>
            </td>
            <td><%= owner.email %></td>
            <td><%= owner.phone %></td>
            <td>
              <span class="badge bg-secondary rounded-pill"><%= owner.pets.size %></span>
            </td>
            <td>
              <%= link_to "Edit", edit_owner_path(owner), class: "btn btn-sm btn-outline-warning me-1" %>
              <%= button_to "Delete", owner_path(owner), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: "Are you sure?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>