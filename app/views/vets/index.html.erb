<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Veterinarians Directory</h1>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Full Name</th>
          <th>Email</th>
          <th>Specialization</th>
        </tr>
      </thead>
      <tbody>
        <% @vets.each do |vet| %>
          <tr>
            <td>
              <%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet), class: "text-decoration-none fw-bold text-info" %>
            </td>
            <td><%= vet.email %></td>
            <td><span class="badge bg-info text-dark"><%= vet.specialization %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>